NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<tu-anon-key>
NEXT_PUBLIC_POSTHOG_KEY=<tu-posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
RESEND_API_KEY=<tu-resend-api-key>

# Conexion directa a Postgres (Dashboard > Settings > Database > Connection
# string > pestaña "URI", NO la del pooler). Solo la necesitas para correr
# `npm run db:migrate`; nunca la commitees.
SUPABASE_DB_URL=postgresql://postgres:<tu-password>@db.<tu-proyecto>.supabase.co:5432/postgres
